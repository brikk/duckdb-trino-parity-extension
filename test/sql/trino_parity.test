# name: test/sql/trino_parity.test
# description: Parity with Trino on Unicode + edge-case inputs where DuckDB's built-ins diverge. Covers native trino_lower / upper / reverse / trim family / normalize, ~80 macro renames, and the trino_meta() catalog.
# group: [sql]

# Before LOAD: functions don't exist.
statement error
SELECT trino_lower('x');
----
Catalog Error

require trino_parity

# -----------------------------------------------------------------------------
# trino_lower
# -----------------------------------------------------------------------------

query I
SELECT trino_lower('HELLO WORLD');
----
hello world

query I
SELECT trino_lower('');
----
(empty)

query I
SELECT trino_lower(NULL);
----
NULL

# Turkish capital dotted I (U+0130).
#   DuckDB built-in lower() = 'i'           (1 code point, simple case folding)
#   Trino + ICU root        = 'i' + U+0307  (2 code points, full case folding)
# Assert bytes via BLOB equality to side-step renderer ambiguity.
query I
SELECT encode(trino_lower(chr(304))) = '\x69\xCC\x87'::BLOB;
----
true

# Same input, code-point length must be 2 (not 1).
query I
SELECT length(trino_lower(chr(304)));
----
2

# Greek capital sigma → medial sigma under root locale (final-sigma rule is
# locale-specific and not applied here, matching Java Locale.ROOT).
query I
SELECT trino_lower('Σ');
----
σ

# ASCII inside a larger non-ASCII string — case folding leaves non-letters alone.
query I
SELECT trino_lower('Café 日本');
----
café 日本

# -----------------------------------------------------------------------------
# trino_upper
# -----------------------------------------------------------------------------

query I
SELECT trino_upper('hello world');
----
HELLO WORLD

query I
SELECT trino_upper('');
----
(empty)

query I
SELECT trino_upper(NULL);
----
NULL

# German sharp s (U+00DF).
#   DuckDB built-in upper() = 'ẞ'  (U+1E9E, 1 code point)
#   Trino + ICU root        = 'SS' (2 code points, full case folding expansion)
query I
SELECT trino_upper('ß');
----
SS

query I
SELECT length(trino_upper('ß'));
----
2

# Multiple ß expand independently.
query I
SELECT trino_upper('straße strauß');
----
STRASSE STRAUSS

# -----------------------------------------------------------------------------
# trino_reverse
# -----------------------------------------------------------------------------

query I
SELECT trino_reverse('hello');
----
olleh

query I
SELECT trino_reverse('');
----
(empty)

query I
SELECT trino_reverse(NULL);
----
NULL

# Decomposed café: 'c' 'a' 'f' 'e' + U+0301. Reversed by code point:
# U+0301 'e' 'f' 'a' 'c' — 5 code points, 6 bytes (combining acute is 2-byte UTF-8).
# DuckDB built-in reverse() keeps the 'e' + U+0301 grapheme together; ours splits.
query I
SELECT encode(trino_reverse('cafe' || chr(769))) = '\xCC\x81\x65\x66\x61\x63'::BLOB;
----
true

query I
SELECT length(trino_reverse('cafe' || chr(769)));
----
5

# Single 4-byte emoji (1 code point) stays intact, just relocated.
query I
SELECT trino_reverse('a😀b');
----
b😀a

query I
SELECT length(trino_reverse('a😀b'));
----
3

# ZWJ family emoji '👨‍👩‍👧' (5 code points: man, ZWJ, woman, ZWJ, girl).
# Trino reverse → girl, ZWJ, woman, ZWJ, man (bytes flipped per code point).
# DuckDB built-in reverse leaves it unchanged (treats as one grapheme cluster).
query I
SELECT encode(trino_reverse('👨‍👩‍👧')) = '\xF0\x9F\x91\xA7\xE2\x80\x8D\xF0\x9F\x91\xA9\xE2\x80\x8D\xF0\x9F\x91\xA8'::BLOB;
----
true

query I
SELECT length(trino_reverse('👨‍👩‍👧'));
----
5

# CJK round-trip: pure code-point reverse on 3 BMP characters.
query I
SELECT trino_reverse('日本語');
----
語本日

# -----------------------------------------------------------------------------
# Composability — confirm functions chain cleanly. Note: lower/upper do NOT
# round-trip for inputs like 'İ' (full case folding expands U+0130 → 'i'+U+0307
# on the way down, and the upper coming back is 'I'+U+0307, not U+0130).
# Use ASCII inputs for the round-trip assertion.
# -----------------------------------------------------------------------------

query I
SELECT trino_upper(trino_lower('HELLO WORLD'));
----
HELLO WORLD

query I
SELECT trino_reverse(trino_reverse('hello'));
----
hello

# Explicit non-round-trip pin for full-case-folding: trino_upper of
# trino_lower('İ') gives 'I' + U+0307, NOT back to U+0130. This is the
# documented Trino/Java behaviour and the contract we're enforcing.
query I
SELECT encode(trino_upper(trino_lower(chr(304)))) = '\x49\xCC\x87'::BLOB;
----
true

# -----------------------------------------------------------------------------
# trino_trim / trino_ltrim / trino_rtrim — native (ICU u_isWhitespace,
# Java's Character.isWhitespace semantics).
# -----------------------------------------------------------------------------

# ASCII space — both ends.
query I
SELECT trino_trim('  hello  ');
----
hello

# Java whitespace coverage: tab, LF, CR, FF, VT all stripped.
query I
SELECT trino_trim(chr(9) || chr(10) || chr(13) || 'hi' || chr(11) || chr(12));
----
hi

# U+1680 OGHAM SPACE MARK — stripped (Java treats as whitespace).
query I
SELECT trino_trim(chr(5760) || 'hi' || chr(5760));
----
hi

# U+3000 IDEOGRAPHIC SPACE — stripped.
query I
SELECT trino_trim(chr(12288) || 'hi' || chr(12288));
----
hi

# U+00A0 NBSP — NOT stripped (Java spec excludes; "non-breaking"). Assert
# byte-identical to input since rendering NBSP in the test file is fragile.
query I
SELECT encode(trino_trim(chr(160) || 'hi' || chr(160))) = encode(chr(160) || 'hi' || chr(160));
----
true

# U+2007 FIGURE SPACE — NOT stripped.
query I
SELECT encode(trino_trim(chr(8199) || 'hi' || chr(8199))) = encode(chr(8199) || 'hi' || chr(8199));
----
true

# U+202F NARROW NBSP — NOT stripped.
query I
SELECT encode(trino_trim(chr(8239) || 'hi' || chr(8239))) = encode(chr(8239) || 'hi' || chr(8239));
----
true

# Left-only / right-only. Spaces on the OTHER end must survive — sqllogic
# strips trailing whitespace from expected output lines, so assert via
# BLOB equality for the form with trailing spaces.
query I
SELECT trino_ltrim('  hello  ') = 'hello  ';
----
true

query I
SELECT trino_rtrim('  hello  ');
----
  hello

# Empty / all-whitespace.
query I
SELECT trino_trim('');
----
(empty)

query I
SELECT trino_trim('   ');
----
(empty)

# NULL propagation.
query I
SELECT trino_trim(NULL);
----
NULL

# -----------------------------------------------------------------------------
# trino_normalize — native (ICU Normalizer2 with NFC/NFD/NFKC/NFKD instances).
# -----------------------------------------------------------------------------

# Single-arg form defaults to NFC. Decomposed café (5 cp) collapses to
# composed café (4 cp, with U+00E9 'é').
query I
SELECT trino_normalize('cafe' || chr(769));
----
café

query I
SELECT length(trino_normalize('cafe' || chr(769)));
----
4

# Two-arg form: NFD decomposes composed 'é' (U+00E9) into 'e' + U+0301.
query I
SELECT length(trino_normalize('café', 'NFD'));
----
5

query I
SELECT encode(trino_normalize('café', 'NFD')) = '\x63\x61\x66\x65\xCC\x81'::BLOB;
----
true

# Case-insensitive form name.
query I
SELECT trino_normalize('cafe' || chr(769), 'nfc');
----
café

# NFKC: compatibility decomposition + canonical composition. Ligature U+FB01 ('ﬁ')
# decomposes to 'f' + 'i' under NFKC, but stays as ligature under NFC.
# Use chr/length to assert byte-precisely since the ligature renders similarly to 'fi'.

# NFC preserves the ligature (1 code point).
query I
SELECT length(trino_normalize(chr(64257), 'NFC'));
----
1

query I
SELECT trino_normalize(chr(64257), 'NFC') = chr(64257);
----
true

# NFKC decomposes to 'f' + 'i' (2 code points, ASCII).
query I
SELECT trino_normalize(chr(64257), 'NFKC') = 'fi';
----
true

# NFKD: full compatibility decomposition (same chars here, since 'f' and 'i' are already atomic).
query I
SELECT length(trino_normalize(chr(64257), 'NFKD'));
----
2

# Empty + NULL.
query I
SELECT trino_normalize('');
----
(empty)

query I
SELECT trino_normalize(NULL);
----
NULL

# Unknown form raises a clear error.
statement error
SELECT trino_normalize('x', 'bogus');
----
trino_normalize: unsupported form 'bogus'

# =============================================================================
# SQL alias macros + trino_meta()
#
# The extension also loads src/trino_function_aliases.sql at LOAD time, which
# registers ~60 trino_<name> macros (length / substring / abs / regexp_like / …)
# and the trino_meta() table macro that catalogs every pushable name+arity.
# One spot check per category — the macros are thin renames over DuckDB
# built-ins, so we're verifying registration succeeded, not the underlying
# semantics. Trino-vs-DuckDB semantic divergences (e.g. concat NULL handling,
# trim whitespace set) are pinned in the parent connector's
# TestTrinoFunctionAliases cross-engine harness, not here.
# =============================================================================

# string
query I
SELECT trino_length('hello');
----
5

query I
SELECT trino_strpos('foobar', 'bar');
----
4

query I
SELECT trino_concat_ws('-', 'a', 'b', 'c');
----
a-b-c

# numeric
query I
SELECT trino_abs(-7);
----
7

query I
SELECT trino_pi() > 3.14 AND trino_pi() < 3.15;
----
true

query I
SELECT trino_bitwise_and(12, 10);
----
8

# regex
query I
SELECT trino_regexp_like('hello world', 'w(o|0)rld');
----
true

# Trino's regexp_replace replaces ALL matches by default. The macro forces 'g'
# so a non-anchored pattern strips every occurrence, not just the first.
query I
SELECT trino_regexp_replace('aaa', 'a', 'b');
----
bbb

# encoding
query I
SELECT trino_to_hex('A'::BLOB);
----
41

query I
SELECT trino_url_encode('a b');
----
a%20b

# distance
query I
SELECT trino_levenshtein_distance('kitten', 'sitting');
----
3

# hash — Trino returns VARBINARY; macros wrap unhex(...) so the macro return
# IS a BLOB. md5 of empty input is the standard d41d8cd98f00b204e9800998ecf8427e.
query I
SELECT hex(trino_md5(''::BLOB));
----
D41D8CD98F00B204E9800998ECF8427E

# date
query I
SELECT trino_year(DATE '2024-12-30');
----
2024

# day_of_week: Trino is ISO (Mon=1, Sun=7), NOT DuckDB's default dayofweek
# (Sun=0). The macro uses isodow.
query I
SELECT trino_day_of_week(DATE '2024-01-07');
----
7

# conditional
query I
SELECT trino_if(true, 'yes', 'no');
----
yes

query I
SELECT trino_if(false, 'yes');
----
NULL

# -----------------------------------------------------------------------------
# trino_meta() — authoritative catalog of pushable (name, arity) entries.
# -----------------------------------------------------------------------------

# Total row count is the contract with the Java-side PUSHABLE_FUNCTIONS parity
# test (testJavaPushableSetMatchesDuckDbMeta). If this number changes the
# parent connector's test will fail until the Java set is updated too. Bump
# both sides in the same change.
query I
SELECT count(*) FROM trino_meta();
----
93

# Row shape: three columns, expected types.
query III
SELECT trino_name, arg_count, category FROM trino_meta() WHERE trino_name = 'length' AND arg_count = 1;
----
length	1	string

# Native-backed functions still appear in trino_meta — they're pushable, they
# just happen to be implemented in C++ rather than as macros.
query I
SELECT count(*) FROM trino_meta() WHERE trino_name IN ('lower', 'upper', 'reverse');
----
3

# Multi-arity functions: substring has both 2- and 3-arg overloads listed.
query I
SELECT count(*) FROM trino_meta() WHERE trino_name = 'substring';
----
2

# All categories present (string, numeric, regex, encoding, distance, hash,
# date, conditional — 8 total).
query I
SELECT count(DISTINCT category) FROM trino_meta();
----
8
